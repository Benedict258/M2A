    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mysten/deepbook-v3": "^1.5.0",
    "@mysten/sui": "^2.16.2",
    "@mysten/walrus": "^1.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "nodemailer": "^9.0.1",
    "openai": "^6.37.0",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^8.0.1",
